<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edabit Challenge Tracker</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>Edabit Problem Solving</h1>
        <div class="stats">
            <p>Total Points: <span id="total-points">0</span></p>
        </div>

        <div class="input-section">
            <input type="text" id="task-name" placeholder="Task Name">
            <select id="difficulty">
                <option value="5">Easy (5 pts)</option>
                <option value="10">Medium (10 pts)</option>
                <option value="20">Hard (20 pts)</option>
            </select>
            <button onclick="addTask()">Add Completed Task</button>
        </div>

        <ul id="task-list">
            <!-- Tasks will appear here -->
        </ul>
    </div>
    <script src="script.js"></script>
</body>
</html>
